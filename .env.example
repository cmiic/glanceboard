# AMO (addons.mozilla.org) credentials for `npm run submit` (alias for `wxt submit`).
# Copy this file to `.env` (gitignored) and fill in real values — never commit secrets.
# Get the issuer (API key) + secret at https://addons.mozilla.org/developers/addon/api/key/
FIREFOX_EXTENSION_ID=glanceboard@miic.at
FIREFOX_JWT_ISSUER=user:000000:000
FIREFOX_JWT_SECRET=replace-with-your-amo-api-secret
FIREFOX_CHANNEL=listed
