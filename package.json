{
  "name": "glanceboard",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Glanceboard — an at-a-glance wall of live website previews (Firefox extension)",
  "engines": {
    "node": ">=24.0.0"
  },
  "scripts": {
    "dev": "wxt -b firefox",
    "build": "wxt build -b firefox",
    "zip": "wxt zip -b firefox",
    "prepare": "wxt prepare",
    "lint": "npm run lint:js && npm run lint:md",
    "lint:js": "eslint .",
    "lint:md": "markdownlint-cli2",
    "test": "node --test"
  },
  "dependencies": {
    "chart.js": "4.5.1",
    "vue": "3.5.35",
    "vue-chartjs": "5.3.3"
  },
  "devDependencies": {
    "@eslint/js": "10.0.1",
    "@wxt-dev/module-vue": "1.0.3",
    "eslint": "10.4.1",
    "eslint-plugin-vue": "10.9.2",
    "globals": "17.6.0",
    "markdownlint-cli2": "0.22.1",
    "vue-eslint-parser": "10.4.1",
    "wxt": "0.20.26"
  },
  "overrides": {
    "tmp": "0.2.7"
  }
}
