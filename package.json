{
  "name": "glanceboard",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Glanceboard — an at-a-glance wall of live website previews (Firefox extension)",
  "engines": {
    "node": ">=24.0.0"
  },
  "scripts": {
    "build": "vite build",
    "watch": "vite build --watch",
    "start": "web-ext run --source-dir dist",
    "start:android": "web-ext run --target firefox-android --source-dir dist",
    "lint": "npm run lint:js && npm run lint:md",
    "lint:js": "eslint .",
    "lint:md": "markdownlint-cli2",
    "lint:ext": "web-ext lint --source-dir dist",
    "test": "node --test"
  },
  "dependencies": {
    "chart.js": "4.5.1",
    "vue": "3.5.35",
    "vue-chartjs": "5.3.3"
  },
  "devDependencies": {
    "@eslint/js": "10.0.1",
    "@vitejs/plugin-vue": "6.0.7",
    "eslint": "10.4.1",
    "eslint-plugin-vue": "10.9.2",
    "globals": "17.6.0",
    "markdownlint-cli2": "0.22.1",
    "vite": "8.0.16",
    "vite-plugin-web-extension": "4.5.1",
    "vue-eslint-parser": "10.4.1",
    "web-ext": "10.3.0"
  }
}
